rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Anyone can read event data (public safety info)
    match /zone_density/{zone} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /alerts/{alert} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Attendees can write their own location
    match /attendee_locations/{attendeeId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.uid == attendeeId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
